# Kasoku Server Configuration

# Server
PORT=8080
BASE_URL=http://localhost:8080

# Database
DB_DRIVER=sqlite
DB_DSN=kasoku.db
# For PostgreSQL:
# DB_DRIVER=postgres
# DB_DSN=postgres://user:password@localhost:5432/kasoku?sslmode=disable

# Authentication
JWT_SECRET=change-me-in-production

# OAuth Providers (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# Storage
STORAGE_TYPE=local
STORAGE_PATH=./storage

# For S3:
# STORAGE_TYPE=s3
# S3_BUCKET=my-kasoku-cache
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Billing (optional, for cloud hosting)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
