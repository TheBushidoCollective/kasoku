# Kasoku Production Environment Configuration
# Copy this file to .env and fill in your values

# ===========================
# DOMAIN CONFIGURATION
# ===========================
# Your domain name (required for SSL)
DOMAIN=kasoku.example.com

# Ports (optional, defaults shown)
HTTP_PORT=80
HTTPS_PORT=443

# ===========================
# DATABASE CONFIGURATION
# ===========================
# PostgreSQL password (CHANGE THIS!)
DB_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# ===========================
# SECURITY
# ===========================
# JWT secret for authentication (CHANGE THIS!)
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING_MINIMUM_32_CHARACTERS

# ===========================
# STORAGE CONFIGURATION
# ===========================
# Storage type: local or s3
STORAGE_TYPE=local

# S3 Configuration (only if STORAGE_TYPE=s3)
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ===========================
# STRIPE BILLING (OPTIONAL)
# ===========================
# Leave empty for self-hosted without billing
# Only set these if you want to enable paid plans

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_INDIVIDUAL_PRICE_ID=
STRIPE_TEAM_PRICE_ID=
STRIPE_SUCCESS_URL=https://kasoku.example.com/dashboard?success=true
STRIPE_CANCEL_URL=https://kasoku.example.com/pricing
STRIPE_RETURN_URL=https://kasoku.example.com/dashboard

# ===========================
# NOTES
# ===========================
# For self-hosted deployments:
# - STORAGE_TYPE should be "local"
# - Leave all STRIPE_* variables empty
# - All users will be on "free" plan with unlimited local caching
#
# For cloud/hosted deployments:
# - STORAGE_TYPE can be "s3" for scalability
# - Set STRIPE_* variables to enable billing
# - Users can subscribe to Individual ($5/mo) or Team plans
