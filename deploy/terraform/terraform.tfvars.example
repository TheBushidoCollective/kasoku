# Project Configuration
project_name      = "kasoku"
github_repo       = "TheBushidoCollective/kasoku"
production_branch = "main"

# PR Environments
enable_pr_environments = true

# Server Service
server_root_directory = "server"
server_custom_domain  = "api.kasoku.dev"

# Web Service
web_root_directory = "web"
web_custom_domain  = "app.kasoku.dev"

# GCP DNS (optional - set gcp_project_id to enable)
gcp_project_id        = ""
gcp_dns_zone_name     = "kasoku-dev"
domain                = "kasoku.dev"
server_domain_verify_txt = ""
web_domain_verify_txt    = ""

# OAuth (required - set via TF_VAR_* env vars or here)
github_client_id     = ""
github_client_secret = ""
gitlab_client_id     = ""
gitlab_client_secret = ""

# Stripe Billing (optional - set to enable billing)
stripe_secret_key     = ""
stripe_webhook_secret = ""
